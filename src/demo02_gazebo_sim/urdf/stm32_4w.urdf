<?xml version="1.0" encoding="utf-8"?>
<robot
  name="mycar_description">
  <link name="base_footprint">
    <visual>
      <geometry>
          <sphere radius="0.001"/>
      </geometry>
    </visual>
  </link>
  <link
    name="base_link">
    <inertial>
      <origin
        rpy="0 0 0" />
      <mass
        value="0.2" />
      <inertia
        ixx="0.13741666666666668"
        ixy="0"
        ixz="0"
        iyy="0.1666666666666667"
        iyz="0"
        izz="0.037416666666666674" />
      </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://mycar_description/mesh/diff_4w/base_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.8 0.6 0.1 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://mycar_description/mesh/diff_4w/base_link.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="baselink2basefootprint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0.0 0.0 0.03"/>
  </joint>
  
  <link
    name="laser">
    <inertial>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <mass
        value="0.01" />
      <inertia
        ixx="6.889e-06"
        ixy="0"
        ixz="0"
        iyy="6.889e-06"
        iyz="0"
        izz="6.889e-06" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://mycar_description/mesh/diff_4w/laser_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.15 0.15 0.15 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://mycar_description/mesh/diff_4w/laser_link.STL" />
      </geometry>
    </collision>
  </link>
  
  
  <joint
    name="laser_joint"
    type="fixed">
    <origin
      xyz="-0.0 -0.0 0.13116"
      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="laser" />
    <axis
      xyz="0 0 0" />
  </joint>
  
  <link
    name="camera">
    <inertial>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <mass
        value="0.001" />
      <inertia
        ixx="6.889e-07"
        ixy="0"
        ixz="0"
        iyy="6.889e-07"
        iyz="0"
        izz="6.889e-07" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://mycar_description/mesh/diff_4w/camera_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.3 0.3 0.3 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://mycar_description/mesh/diff_4w/camera_link.STL" />
      </geometry>
    </collision>
  </link>
  
  <joint
    name="camera_joint"
    type="fixed">
    <origin
      xyz="0.18522 0 0.03"
      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="camera" />
    <axis
      xyz="0 0 0" />
  </joint>
  
  <link
    name="left_former_link">
    <inertial>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <mass
        value="0.1" />
      <inertia
        ixx="6.889e-05"
        ixy="0"
        ixz="0"
        iyy="6.889e-05"
        iyz="0"
        izz="6.889e-05" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://mycar_description/mesh/diff_4w/left_former_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.1 0.1 0.8 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://mycar_description/mesh/diff_4w/left_former_link.STL" />
      </geometry>
      <surface>
          <contact>
            <ode>
              <kp>1e+07</kp>
              <kd>1</kd>
            </ode>
          </contact>
          <friction>
            <ode>
              <mu>1000000</mu>
              <mu2>10000000</mu2>
              <slip1>0</slip1>
              <slip2>0</slip2>
              <fdir1>0 0 1</fdir1>
            </ode>
          </friction>
        </surface>
    </collision>
  </link>
  <joint
    name="left_former_joint"
    type="continuous">
    <origin
      xyz="0.11 0.15 0.017306"
      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="left_former_link" />
    <axis
      xyz="0 1 0" />
  </joint>
  <link
    name="left_rear_link">
    <inertial>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <mass
        value="0.1" />
      <inertia
        ixx="6.889e-05"
        ixy="0"
        ixz="0"
        iyy="6.889e-05"
        iyz="0"
        izz="6.889e-05" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://mycar_description/mesh/diff_4w/left_rear_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.1 0.1 0.8 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://mycar_description/mesh/diff_4w/left_rear_link.STL" />
      </geometry>
      <surface>
          <contact>
            <ode>
              <kp>1e+07</kp>
              <kd>1</kd>
            </ode>
          </contact>
          <friction>
            <ode>
              <mu>1000000</mu>
              <mu2>10000000</mu2>
              <slip1>0</slip1>
              <slip2>0</slip2>
              <fdir1>0 0 1</fdir1>
            </ode>
          </friction>
        </surface>
    </collision>
  </link>
  <joint
    name="left_rear_joint"
    type="continuous">
    <origin
      xyz="-0.11 0.15 0.017306"
      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="left_rear_link" />
    <axis
      xyz="0 1 0" />
  </joint>
  <link
    name="right_former_link">
    <inertial>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <mass
        value="0.1" />
      <inertia
        ixx="6.889e-05"
        ixy="0"
        ixz="0"
        iyy="6.889e-05"
        iyz="0"
        izz="6.889e-05" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://mycar_description/mesh/diff_4w/right_former_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.1 0.1 0.8 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://mycar_description/mesh/diff_4w/right_former_link.STL" />
      </geometry>
      <surface>
          <contact>
            <ode>
              <kp>1e+07</kp>
              <kd>1</kd>
            </ode>
          </contact>
          <friction>
            <ode>
              <mu>1000000</mu>
              <mu2>10000000</mu2>
              <slip1>0</slip1>
              <slip2>0</slip2>
              <fdir1>0 0 1</fdir1>
            </ode>
          </friction>
        </surface>
    </collision>
  </link>
  <joint
    name="right_former_joint"
    type="continuous">
    <origin
      xyz="0.11 -0.15 0.017306"
      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="right_former_link" />
    <axis
      xyz="0 1 0" />
  </joint>
  <link
    name="right_rear_link">
    <inertial>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <mass
        value="0.1" />
      <inertia
        ixx="6.889e-05"
        ixy="0"
        ixz="0"
        iyy="6.889e-05"
        iyz="0"
        izz="6.889e-05" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://mycar_description/mesh/diff_4w/right_rear_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.1 0.1 0.8 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://mycar_description/mesh/diff_4w/right_rear_link.STL" />
      </geometry>
      <surface>
          <contact>
            <ode>
              <kp>1e+07</kp>
              <kd>1</kd>
            </ode>
          </contact>
          <friction>
            <ode>
              <mu>1000000</mu>
              <mu2>10000000</mu2>
              <slip1>0</slip1>
              <slip2>0</slip2>
              <fdir1>0 0 1</fdir1>
            </ode>
          </friction>
        </surface>
    </collision>
  </link>
  <joint
    name="right_rear_joint"
    type="continuous">
    <origin
      xyz="-0.11 -0.15 0.017306"
      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="right_rear_link" />
    <axis
      xyz="0 1 0" />
  </joint>
  <gazebo>
    <plugin
        filename="ignition-gazebo-diff-drive-system"
        name="ignition::gazebo::systems::DiffDrive">
        <left_joint>left_former_joint</left_joint>
        <left_joint>left_rear_joint</left_joint>
        <right_joint>right_former_joint</right_joint>
        <right_joint>right_rear_joint</right_joint>
        <wheel_separation>0.4</wheel_separation>
        <wheel_radius>0.0415</wheel_radius>
        <odom_publish_frequency>50</odom_publish_frequency>
        <frame_id>odom</frame_id>
        <child_frame_id>base_footprint</child_frame_id>
        <topic>/cmd_vel</topic>
        <max_linear_acceleration>10</max_linear_acceleration>
        <min_linear_acceleration>-10</min_linear_acceleration>
        <max_angular_acceleration>10</max_angular_acceleration>
        <min_angular_acceleration>-10</min_angular_acceleration>
        <max_linear_velocity>0.5</max_linear_velocity>
        <min_linear_velocity>-0.5</min_linear_velocity>
        <max_angular_velocity>1</max_angular_velocity>
        <min_angular_velocity>-1</min_angular_velocity>
        <!-- <max_torque>1000</max_torque> -->
      </plugin>
  </gazebo>
  <!-- 关节状态发布 -->
  <gazebo>
    <plugin filename="ignition-gazebo-joint-state-publisher-system"
      name="ignition::gazebo::systems::JointStatePublisher">
    </plugin>
  </gazebo>
</robot>
